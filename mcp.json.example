{
  "mcpServers": {
    "java-codebase-rag": {
      "type": "stdio",
      "command": "/ABSOLUTE/PATH/TO/mcp_lancedb_bundle/.venv/bin/python",
      "args": ["/ABSOLUTE/PATH/TO/mcp_lancedb_bundle/server.py"],
      "env": {
        "JAVA_CODEBASE_RAG_INDEX_DIR": "/ABSOLUTE/PATH/TO/.java-codebase-rag",
        "JAVA_CODEBASE_RAG_SOURCE_ROOT": "/ABSOLUTE/PATH/TO/your-java-project",
        "SBERT_MODEL": "sentence-transformers/all-MiniLM-L6-v2"
      }
    }
  }
}
