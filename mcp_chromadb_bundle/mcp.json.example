{
  "mcpServers": {
    "chromadb-code": {
      "type": "stdio",
      "command": "/ABSOLUTE/PATH/TO/mcp_chromadb_bundle/.venv/bin/python",
      "args": ["/ABSOLUTE/PATH/TO/mcp_chromadb_bundle/server.py"],
      "env": {
        "CHROMA_MCP_PATH": "/ABSOLUTE/PATH/TO/chromadb_data",
        "CHROMA_MCP_CLIENT": "persistent",
        "SBERT_MODEL": "sentence-transformers/all-MiniLM-L6-v2",
        "CHROMA_MCP_PROJECT_ROOT": "/ABSOLUTE/PATH/TO/repo-with-java_index_flow_chroma"
      }
    }
  }
}
