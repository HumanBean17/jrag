{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(.venv/bin/python *)",
      "Bash(.venv/bin/ruff *)",
      "Bash(.venv/bin/pip *)",
      "Bash(gh *)",
      "Read(./**)",
      "Edit(./**)"
    ],
    "deny": [
      "Bash(git push *)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}
