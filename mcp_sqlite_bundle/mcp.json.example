{
  "mcpServers": {
    "sqlite-code": {
      "type": "stdio",
      "command": "/ABSOLUTE/PATH/TO/mcp_sqlite_bundle/.venv/bin/python",
      "args": ["/ABSOLUTE/PATH/TO/mcp_sqlite_bundle/server.py"],
      "env": {
        "SQLITE_CODE_INDEX_DB": "/ABSOLUTE/PATH/TO/java_code_index.sqlite",
        "SBERT_MODEL": "sentence-transformers/all-MiniLM-L6-v2",
        "SQLITE_MCP_PROJECT_ROOT": "/ABSOLUTE/PATH/TO/repo-with-java_index_flow_sqlite"
      }
    }
  }
}
